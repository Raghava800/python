# Python object-oriented programming

class Employee:

	def __init__(self, first, last, salary):

		self.first = first
		self.last = last
		self.salary = salary

	def fullname(self):

		return '{} {}'.format(self.first, self.last)

emp_1 = Employee('Sai', 'Raghavendra', 50000)
emp_2 = Employee('Test','Employee',60000)
		